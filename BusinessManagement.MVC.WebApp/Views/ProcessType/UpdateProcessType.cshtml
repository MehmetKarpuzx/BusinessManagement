@model BusinessManagement.MVC.DTO.ProcessTypeDTOs.UpdateProcessTypeDto
@{
    ViewData["Title"] = "Tipi Düzenle";
}

<div class="glass-card p-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-pen-to-square text-warning me-2"></i>İşlem Tipini Düzenle
        </h2>
        <p class="text-muted">Tip bilgilerini güncelleyebilirsiniz.</p>
    </div>

    <form asp-action="UpdateProcessType" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-12">
                <label asp-for="Name" class="form-label fw-semibold">Tip Adı</label>
                <input asp-for="Name" class="form-control glass-input" required>
            </div>
            <div class="col-md-12">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" class="form-control glass-input" rows="3"></textarea>
            </div>
            
            <div class="col-12 mt-4">
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-warning px-4 text-white font-weight-bold">Güncelle</button>
                </div>
            </div>
        </div>
    </form>
</div>
