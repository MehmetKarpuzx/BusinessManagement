@model BusinessManagement.MVC.DTO.SupplierDTOs.UpdateSupplierDto
@{
    ViewData["Title"] = "Tedarikçiyi Düzenle";
}

<div class="glass-card p-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-pen-to-square text-warning me-2"></i>Tedarikçiyi Düzenle
        </h2>
        <p class="text-muted">Tedarikçi bilgilerini güncelleyebilirsiniz.</p>
    </div>

    <form asp-action="UpdateSupplier" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-semibold">Tedarikçi Adı</label>
                <input asp-for="Name" class="form-control glass-input" required>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" type="email" class="form-control glass-input">
            </div>
            
            <div class="col-md-6">
                <label asp-for="PhoneNumber" class="form-label fw-semibold">Telefon</label>
                <input asp-for="PhoneNumber" class="form-control glass-input" required>
            </div>
            <div class="col-md-6">
                <label asp-for="Adress" class="form-label fw-semibold">Adres</label>
                <input asp-for="Adress" class="form-control glass-input">
            </div>

            <div class="col-md-12">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" class="form-control glass-input" rows="3"></textarea>
            </div>
            
            <div class="col-md-12">
                <div class="form-check form-switch mt-2">
                    <input class="form-check-input" type="checkbox" asp-for="IsDeleted">
                    <label class="form-check-label fw-semibold" asp-for="IsDeleted">Silindi mi?</label>
                </div>
            </div>

            <div class="col-12 mt-4">
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-warning px-4 text-white font-weight-bold">Güncelle</button>
                </div>
            </div>
        </div>
    </form>
</div>
