@model List<BusinessManagement.MVC.DTO.TransferDTOs.ResultTransferDto>
@{
    ViewData["Title"] = "Transferler";
}

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-truck-ramp-box text-primary me-2"></i>Transfer Yönetimi
        </h2>
        <a asp-action="AddTransfer" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Transfer</span>
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th class="ps-4">Transfer Tarihi</th>
                    <th>Üretim ID</th>
                    <th>Miktar</th>
                    <th>Hedef Şube ID</th>
                    <th>Açıklama</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.TransferDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.ProductionId</td>
                        <td class="fw-bold">@item.TransferAmount</td>
                        <td>@item.BranchId</td>
                        <td>@item.Description</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="UpdateTransfer" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteTransfer" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu transfer kaydını silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
