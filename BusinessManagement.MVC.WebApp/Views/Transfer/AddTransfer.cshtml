@model BusinessManagement.MVC.DTO.TransferDTOs.AddTransferDto
@{
    ViewData["Title"] = "Transfer Ekle";
}

<div class="glass-card p-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-plus text-primary me-2"></i>Yeni Transfer Ekle
        </h2>
        <p class="text-muted">Transfer detaylarını giriniz.</p>
    </div>

    <form asp-action="AddTransfer" method="post">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ProductionId" class="form-label fw-semibold">Üretim</label>
                <select asp-for="ProductionId" class="form-select glass-input" asp-items="@ViewBag.Productions" required>
                    <option value="">Üretim Seçiniz...</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="BranchId" class="form-label fw-semibold">Hedef Şube</label>
                <select asp-for="BranchId" class="form-select glass-input" asp-items="@ViewBag.Branches" required>
                    <option value="">Şube Seçiniz...</option>
                </select>
            </div>
            
            <div class="col-md-6">
                <label asp-for="TransferAmount" class="form-label fw-semibold">Transfer Miktarı</label>
                <input asp-for="TransferAmount" type="number" class="form-control glass-input" required>
            </div>
            <div class="col-md-6">
                <label asp-for="TransferDate" class="form-label fw-semibold">Transfer Tarihi</label>
                <input asp-for="TransferDate" type="date" class="form-control glass-input" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
            </div>

            <div class="col-md-12">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" class="form-control glass-input" rows="3"></textarea>
            </div>

            <div class="col-12 mt-4">
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-primary px-4">Kaydet</button>
                </div>
            </div>
        </div>
    </form>
</div>
