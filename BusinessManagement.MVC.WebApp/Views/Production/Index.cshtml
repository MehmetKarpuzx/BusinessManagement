@model List<BusinessManagement.MVC.DTO.ProductionDTOs.ResultProductionDto>
@{
    ViewData["Title"] = "Üretimler";
}

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-industry text-primary me-2"></i>Üretim Yönetimi
        </h2>
        <a asp-action="AddProduction" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Üretim</span>
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th class="ps-4">Tarih</th>
                    <th>Ürün ID</th>
                    <th>Miktar</th>
                    <th>Maliyet</th>
                    <th>Toplam Tutar</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.CreateDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.ProductId</td>
                        <td>@item.Amount</td>
                        <td>@item.CostPrice.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td class="fw-bold text-primary">@item.TotalPrice.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="UpdateProduction" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteProduction" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu üretim kaydını silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
