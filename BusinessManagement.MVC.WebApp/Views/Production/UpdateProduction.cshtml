@model BusinessManagement.MVC.DTO.ProductionDTOs.UpdateProductionDto
@{
    ViewData["Title"] = "Üretimi Düzenle";
}

<div class="glass-card p-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-pen-to-square text-warning me-2"></i>Üretim Kaydını Düzenle
        </h2>
        <p class="text-muted">Üretim detaylarını güncelleyebilirsiniz.</p>
    </div>

    <form asp-action="UpdateProduction" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ProductId" class="form-label fw-semibold">Ürün</label>
                <select asp-for="ProductId" class="form-select glass-input" asp-items="@ViewBag.Products" required>
                    <option value="">Ürün Seçiniz...</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="BranchId" class="form-label fw-semibold">Şube</label>
                <select asp-for="BranchId" class="form-select glass-input" asp-items="@ViewBag.Branches" required>
                    <option value="">Şube Seçiniz...</option>
                </select>
            </div>
            
            <div class="col-md-4">
                <label asp-for="Amount" class="form-label fw-semibold">Miktar</label>
                <input asp-for="Amount" type="number" class="form-control glass-input" required>
            </div>
            <div class="col-md-4">
                <label asp-for="UnitTypeId" class="form-label fw-semibold">Birim</label>
                <select asp-for="UnitTypeId" class="form-select glass-input" asp-items="@ViewBag.Units" required>
                    <option value="">Birim Seçiniz...</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="CostPrice" class="form-label fw-semibold">Birim Maliyet</label>
                <input asp-for="CostPrice" type="number" class="form-control glass-input" required>
            </div>

            <div class="col-md-4">
                <label asp-for="TotalPrice" class="form-label fw-semibold">Toplam Maliyet</label>
                <input asp-for="TotalPrice" type="number" class="form-control glass-input" required>
            </div>
            <div class="col-md-8">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <input asp-for="Description" class="form-control glass-input">
            </div>

            <div class="col-md-6">
                <label asp-for="CreateDate" class="form-label fw-semibold">Üretim Tarihi</label>
                <input asp-for="CreateDate" type="date" class="form-control glass-input" required value="@Model.CreateDate.ToString("yyyy-MM-dd")">
            </div>

            <div class="col-12 mt-4">
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-warning px-4 text-white font-weight-bold">Güncelle</button>
                </div>
            </div>
        </div>
    </form>
</div>
