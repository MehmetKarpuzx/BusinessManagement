@model BusinessManagement.MVC.DTO.OrderDTOs.UpdateOrderDto
@{
    ViewData["Title"] = "Siparişi Düzenle";
}

<div class="glass-card p-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-file-pen text-warning me-2"></i>Siparişi Düzenle
        </h2>
        <p class="text-muted">Sipariş detaylarını güncelleyebilirsiniz.</p>
    </div>

    <form asp-action="UpdateOrder" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="CustomerId" class="form-label fw-semibold">Müşteri <span class="text-danger">*</span></label>
                <select asp-for="CustomerId" class="form-select glass-input" asp-items="@ViewBag.Customers" required>
                    <option value="">Müşteri Seçiniz...</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="BranchId" class="form-label fw-semibold">Şube <span class="text-danger">*</span></label>
                <select asp-for="BranchId" class="form-select glass-input" asp-items="@ViewBag.Branches" required>
                    <option value="">Şube Seçiniz...</option>
                </select>
            </div>
            <div class="col-md-4">
                <label asp-for="ProductId" class="form-label fw-semibold">Ürün <span class="text-danger">*</span></label>
                <select asp-for="ProductId" class="form-select glass-input" asp-items="@ViewBag.Products" required>
                    <option value="">Ürün Seçiniz...</option>
                </select>
            </div>

            <div class="col-md-6">
                <label asp-for="Amount" class="form-label fw-semibold">Miktar <span class="text-danger">*</span></label>
                <input asp-for="Amount" type="number" class="form-control glass-input" required>
            </div>
            <div class="col-md-6">
                <label asp-for="TotalPrice" class="form-label fw-semibold">Toplam Fiyat <span class="text-danger">*</span></label>
                <input asp-for="TotalPrice" type="number" class="form-control glass-input" required>
            </div>

            <div class="col-md-12">
                <label asp-for="OrderDate" class="form-label fw-semibold">Sipariş Tarihi <span class="text-danger">*</span></label>
                <input asp-for="OrderDate" type="date" class="form-control glass-input" required value="@Model.OrderDate.ToString("yyyy-MM-dd")">
            </div>

            <div class="col-md-6">
                <label asp-for="CargoCompanyId" class="form-label fw-semibold">Kargo Firması</label>
                <select asp-for="CargoCompanyId" class="form-select glass-input" asp-items="@ViewBag.CargoCompanies">
                    <option value="">Kargo Firması Seçiniz...</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="OrderStatus" class="form-label fw-semibold">Sipariş Durumu <span class="text-danger">*</span></label>
                <select asp-for="OrderStatus" class="form-select glass-input" asp-items="Html.GetEnumSelectList<BusinessManagement.MVC.Domain.Enums.OrderStatus>()"></select>
            </div>

            <div class="col-md-6">
                <label asp-for="CargoPrice" class="form-label fw-semibold">Kargo Ücreti</label>
                <input asp-for="CargoPrice" type="number" class="form-control glass-input">
            </div>
            <div class="col-md-6">
                <label asp-for="CargoDescription" class="form-label fw-semibold">Kargo Açıklaması</label>
                <input asp-for="CargoDescription" type="text" class="form-control glass-input">
            </div>

            <div class="col-md-6">
                <label asp-for="DiscountPrice" class="form-label fw-semibold">İndirim Tutarı</label>
                <input asp-for="DiscountPrice" type="number" class="form-control glass-input">
            </div>
            <div class="col-md-6">
                <label asp-for="DiscountDescription" class="form-label fw-semibold">İndirim Açıklaması</label>
                <input asp-for="DiscountDescription" type="text" class="form-control glass-input">
            </div>

            <div class="col-md-6">
                <label asp-for="PaymentReceived" class="form-label fw-semibold">Alınan Ödeme <span class="text-danger">*</span></label>
                <input asp-for="PaymentReceived" type="number" class="form-control glass-input" required>
            </div>
            <div class="col-md-6">
                <label asp-for="RemainderPrice" class="form-label fw-semibold">Kalan Tutar</label>
                <input asp-for="RemainderPrice" type="number" class="form-control glass-input">
            </div>

            <div class="col-md-12">
                <label asp-for="Description" class="form-label fw-semibold">Genel Açıklama</label>
                <input asp-for="Description" class="form-control glass-input">
            </div>

            <div class="col-12 mt-4">
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-warning px-4 text-white font-weight-bold">Güncelle</button>
                </div>
            </div>
        </div>
    </form>
</div>
