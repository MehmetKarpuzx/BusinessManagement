@model List<BusinessManagement.MVC.DTO.OrderDTOs.ResultOrderDto>
@{
    ViewData["Title"] = "Siparişler";
}

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-receipt text-primary me-2"></i>Sipariş Yönetimi
        </h2>
        <a asp-action="AddOrder" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Sipariş</span>
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th class="ps-4">Sipariş Tarihi</th>
                    <th>Müşteri ID</th>
                    <th>Tutar</th>
                    <th>Durum</th>
                    <th>Tahmini Teslim</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.OrderDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.CustomerId</td>
                        <td class="fw-bold">@item.TotalAmount.ToString("C2")</td>
                        <td>
                            @switch (item.OrderStatus)
                            {
                                case BusinessManagement.MVC.Domain.Enums.OrderStatus.Pending:
                                    <span class="badge bg-warning text-dark">Beklemede</span>
                                    break;
                                case BusinessManagement.MVC.Domain.Enums.OrderStatus.Processing:
                                    <span class="badge bg-info text-white">İşleniyor</span>
                                    break;
                                case BusinessManagement.MVC.Domain.Enums.OrderStatus.Shipped:
                                    <span class="badge bg-primary text-white">Sevk Edildi</span>
                                    break;
                                case BusinessManagement.MVC.Domain.Enums.OrderStatus.Completed:
                                    <span class="badge bg-success text-white">Tamamlandı</span>
                                    break;
                                case BusinessManagement.MVC.Domain.Enums.OrderStatus.Cancelled:
                                    <span class="badge bg-danger text-white">İptal Edildi</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary text-white">Bilinmiyor</span>
                                    break;
                            }
                        </td>
                        <td>@(item.EstimatedDeliveryDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="UpdateOrder" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteOrder" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu siparişi silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
