@model List<BusinessManagement.MVC.DTO.ProductDTOs.ResultProductDto>

<style>
    .img-zoomable:hover {
        transform: scale(1.1);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        z-index: 10;
        transition: all 0.2s ease-in-out;
    }
</style>

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-shirt text-primary me-2"></i>Ürün Yönetimi
        </h2>
        <a asp-action="AddProduct" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Ürün</span>
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th class="ps-4">Görsel</th>
                    <th>Ürün Adı</th>
                    <th>Bireysel Fiyat</th>
                    <th>Kurumsal Fiyat</th>
                    <th>Toptan Fiyat</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            @if (!string.IsNullOrEmpty(item.PhotoUrl))
                            {
                                <img src="@item.PhotoUrl" alt="@item.Name" class="rounded-3 img-zoomable" style="width: 45px; height: 45px; object-fit: cover; border: 1px solid rgba(255,255,255,0.2); cursor: pointer;" onclick="showImageModal('@item.PhotoUrl', '@item.Name.Replace("'", "\\'")')" title="Büyütmek için tıklayın">
                            }
                            else
                            {
                                <div class="bg-light d-flex align-items-center justify-content-center rounded-3" style="width: 45px; height: 45px; border: 1px solid rgba(255,255,255,0.2);">
                                    <i class="fa-solid fa-image text-muted"></i>
                                </div>
                            }
                        </td>
                        <td>
                            <span class="fw-semibold">@item.Name</span>
                        </td>
                        <td>@item.PersonelPrice.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td>@item.CorporatePrice.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td>@item.WholesalePrice.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="UpdateProduct" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteProduct" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu ürünü silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

</div>

@* İlgili modal ve script artık _Layout.cshtml içerisinde tanımlı olduğu için buradan kaldırıldı. *@
