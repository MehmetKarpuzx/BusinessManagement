@model List<BusinessManagement.MVC.DTO.PaymentDTOs.ResultPaymentDto>
@{
    ViewData["Title"] = "Ödemeler";
}

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-money-bill-transfer text-primary me-2"></i>Ödeme Yönetimi
        </h2>
        <a asp-action="AddPayment" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Ödeme</span>
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th class="ps-4">Ödeme Tarihi</th>
                    <th>Sipariş ID</th>
                    <th>Tutar</th>
                    <th>Açıklama</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.PaymentDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.OrderId</td>
                        <td class="fw-bold text-success">@item.Amount.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))</td>
                        <td>@item.Description</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="UpdatePayment" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeletePayment" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu ödemeyi silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
