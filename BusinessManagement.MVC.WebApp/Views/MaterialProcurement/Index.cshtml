@model List<BusinessManagement.MVC.DTO.MaterialProcurementDTOs.ResultMaterialProcurementDto>
@{
    ViewData["Title"] = "Hammadde Tedarikleri";
}

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-cart-flatbed-suitcases text-primary me-2"></i>Hammadde Tedarik Yönetimi
        </h2>
        <a asp-action="AddMaterialProcurement" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Tedarik</span>
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th class="ps-4">Tarih</th>
                    <th>Miktar</th>
                    <th>Birim Fiyat</th>
                    <th>Toplam</th>
                    <th>Fatura No</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.ProcurementDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.Amount</td>
                        <td>@((item.UnitPrice ?? 0).ToString("C2"))</td>
                        <td class="fw-bold text-primary">@((item.TotalPrice ?? 0).ToString("C2"))</td>
                        <td>@(item.InvoiceNo?.ToString() ?? "-")</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="UpdateMaterialProcurement" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteMaterialProcurement" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu tedarik kaydını silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
