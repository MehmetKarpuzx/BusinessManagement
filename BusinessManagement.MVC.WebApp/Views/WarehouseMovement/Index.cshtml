@model List<BusinessManagement.MVC.DTO.WarehouseMovementDTOs.ResultWarehouseMovementDto>
@{
    ViewData["Title"] = "Depo Hareketleri";
}

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-warehouse text-primary me-2"></i>Depo Hareket Yönetimi
        </h2>
        <a asp-action="AddWarehouseMovement" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fa-solid fa-plus"></i>
            <span>Yeni Hareket</span>
        </a>
    </div>

    <div class="table-responsive">
        <table class="table custom-table">
            <thead>
                <tr>
                    <th class="ps-4">Tarih</th>
                    <th>İşlem Tipi ID</th>
                    <th>Hammadde ID</th>
                    <th>Miktar</th>
                    <th>Toplam Tutar</th>
                    <th>Şube ID</th>
                    <th class="text-end pe-4">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">@item.TransactionDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.ProcessTypeId</td>
                        <td>@item.MaterialId</td>
                        <td>@item.Amount</td>
                        <td class="fw-bold">@(item.TotalPrice.ToString("C2"))</td>
                        <td>@item.BranchId</td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="UpdateWarehouseMovement" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <form asp-action="DeleteWarehouseMovement" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bu depo hareketini silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Sil">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
