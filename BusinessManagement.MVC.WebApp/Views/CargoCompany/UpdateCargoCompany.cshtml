@model BusinessManagement.MVC.DTO.CargoCompanyDTOs.UpdateCargoCompanyDto
@{
    ViewData["Title"] = "Kargo Firması Düzenle";
}

<div class="glass-card p-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-pen-to-square text-warning me-2"></i>Kargo Firması Düzenle
        </h2>
        <p class="text-muted">Firma bilgilerini güncelleyebilirsiniz.</p>
    </div>

    <form asp-action="UpdateCargoCompany" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-12">
                <label asp-for="Name" class="form-label fw-semibold">Firma Adı</label>
                <input asp-for="Name" class="form-control glass-input" placeholder="Firma adını giriniz..." required>
            </div>
            <div class="col-md-12">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" class="form-control glass-input" rows="3" placeholder="Açıklama giriniz..."></textarea>
            </div>
            
            <div class="col-12 mt-4">
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-warning px-4 text-white font-weight-bold">Güncelle</button>
                </div>
            </div>
        </div>
    </form>
</div>
