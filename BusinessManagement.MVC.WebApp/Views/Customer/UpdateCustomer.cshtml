@model BusinessManagement.MVC.DTO.CustomerDTOs.UpdateCustomerDto
@{
    ViewData["Title"] = "Müşteri Düzenle";
}

<div class="glass-card p-4">
    <div class="mb-4">
        <h2 class="fw-bold mb-0">
            <i class="fa-solid fa-user-pen text-warning me-2"></i>Müşteri Düzenle
        </h2>
        <p class="text-muted">Müşteri bilgilerini aşağıdan güncelleyebilirsiniz.</p>
    </div>

    <form asp-action="UpdateCustomer" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-semibold">Adı</label>
                <input asp-for="Name" class="form-control glass-input" required>
            </div>
            <div class="col-md-6">
                <label asp-for="Surname" class="form-label fw-semibold">Soyadı</label>
                <input asp-for="Surname" class="form-control glass-input" required>
            </div>
            
            <div class="col-md-4">
                <label asp-for="PhoneNumber" class="form-label fw-semibold">Telefon</label>
                <input asp-for="PhoneNumber" class="form-control glass-input" required>
            </div>
            <div class="col-md-4">
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" type="email" class="form-control glass-input">
            </div>
            <div class="col-md-4">
                <label asp-for="CustomerTypeId" class="form-label fw-semibold">Müşteri Tipi</label>
                <select asp-for="CustomerTypeId" class="form-select glass-input" asp-items="@ViewBag.CustomerTypes" required>
                    <option value="">Seçiniz...</option>
                </select>
            </div>

            <div class="col-md-4">
                <label asp-for="City" class="form-label fw-semibold">Şehir</label>
                <input asp-for="City" class="form-control glass-input">
            </div>
            <div class="col-md-8">
                <label asp-for="Adress" class="form-label fw-semibold">Adres</label>
                <input asp-for="Adress" class="form-control glass-input">
            </div>

            <div class="col-md-4">
                <label asp-for="Tckn" class="form-label fw-semibold">TCKN</label>
                <input asp-for="Tckn" class="form-control glass-input">
            </div>
            <div class="col-md-4">
                <label asp-for="TaxNumber" class="form-label fw-semibold">Vergi No</label>
                <input asp-for="TaxNumber" class="form-control glass-input">
            </div>
            <div class="col-md-4">
                <label asp-for="TaxOffice" class="form-label fw-semibold">Vergi Dairesi</label>
                <input asp-for="TaxOffice" class="form-control glass-input">
            </div>

            <div class="col-md-6">
                <label asp-for="RegistrationNumber" class="form-label fw-semibold">Kayıt No</label>
                <input asp-for="RegistrationNumber" class="form-control glass-input">
            </div>
            <div class="col-md-6">
                <label asp-for="Description" class="form-label fw-semibold">Açıklama</label>
                <input asp-for="Description" class="form-control glass-input">
            </div>
            
            <div class="col-md-12">
                <div class="form-check form-switch mt-2">
                    <input class="form-check-input" type="checkbox" asp-for="IsDeleted">
                    <label class="form-check-label fw-semibold" asp-for="IsDeleted">Silindi mi?</label>
                </div>
            </div>

            <div class="col-12 mt-4">
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                    <button type="submit" class="btn btn-warning px-4 text-white font-weight-bold">Güncelle</button>
                </div>
            </div>
        </div>
    </form>
</div>
