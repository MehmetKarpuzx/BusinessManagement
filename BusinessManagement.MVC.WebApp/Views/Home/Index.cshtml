@{
    ViewData["Title"] = "Kontrol Paneli";
}

<div class="container-fluid py-4">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold text-white mb-2" style="text-shadow: 0 5px 15px rgba(0,0,0,0.3);">İşletme Yönetim Sistemi</h1>
            <p class="lead text-white-50">Tüm modüllere buradan erişebilirsiniz.</p>
        </div>
    </div>

    <div class="row g-4 nav-dashboard">
        <!-- Branches -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Branch" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                    <i class="fa-solid fa-code-branch fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Şubeler</h4>
                <p class="text-muted small mb-0">Şube ve lokasyon yönetimi</p>
            </a>
        </div>

        <!-- Cargo Company -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="CargoCompany" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-info bg-opacity-10 text-info mb-3 mx-auto">
                    <i class="fa-solid fa-truck-fast fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Kargo Firmaları</h4>
                <p class="text-muted small mb-0">Anlaşmalı kargo yönetimi</p>
            </a>
        </div>

        <!-- Customers -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Customer" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-success bg-opacity-10 text-success mb-3 mx-auto">
                    <i class="fa-solid fa-users fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Müşteriler</h4>
                <p class="text-muted small mb-0">Müşteri portföy yönetimi</p>
            </a>
        </div>

        <!-- Customer Types -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="CustomerType" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-secondary bg-opacity-10 text-secondary mb-3 mx-auto">
                    <i class="fa-solid fa-tags fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Müşteri Tipleri</h4>
                <p class="text-muted small mb-0">Kategorizasyon ayarları</p>
            </a>
        </div>

        <!-- Materials -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Material" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-warning bg-opacity-10 text-warning mb-3 mx-auto">
                    <i class="fa-solid fa-box-open fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Hammaddeler</h4>
                <p class="text-muted small mb-0">Hammadde stok listesi</p>
            </a>
        </div>

        <!-- Material Procurements -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="MaterialProcurement" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-danger bg-opacity-10 text-danger mb-3 mx-auto">
                    <i class="fa-solid fa-cart-flatbed-suitcases fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Hammadde Alımları</h4>
                <p class="text-muted small mb-0">Tedarik ve satın alma</p>
            </a>
        </div>

        <!-- Orders -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Order" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                    <i class="fa-solid fa-receipt fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Siparişler</h4>
                <p class="text-muted small mb-0">Satış ve sipariş takibi</p>
            </a>
        </div>

        <!-- Payments -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Payment" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-success bg-opacity-10 text-success mb-3 mx-auto">
                    <i class="fa-solid fa-money-bill-transfer fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Ödemeler</h4>
                <p class="text-muted small mb-0">Finansal hareket yönetimi</p>
            </a>
        </div>

        <!-- Payment Methods -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="PaymentMethod" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-dark bg-opacity-10 text-dark mb-3 mx-auto">
                    <i class="fa-solid fa-credit-card fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Ödeme Yöntemleri</h4>
                <p class="text-muted small mb-0">Kredi kartı, nakit, eft</p>
            </a>
        </div>

        <!-- Process Types -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="ProcessType" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-secondary bg-opacity-10 text-secondary mb-3 mx-auto">
                    <i class="fa-solid fa-gears fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">İşlem Tipleri</h4>
                <p class="text-muted small mb-0">Giriş-Çıkış parametreleri</p>
            </a>
        </div>

        <!-- Products -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Product" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-primary bg-opacity-10 text-primary mb-3 mx-auto">
                    <i class="fa-solid fa-shirt fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Ürünler</h4>
                <p class="text-muted small mb-0">Mamul ve ürün yönetimi</p>
            </a>
        </div>

        <!-- Productions -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Production" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-warning bg-opacity-10 text-warning mb-3 mx-auto">
                    <i class="fa-solid fa-industry fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Üretimler</h4>
                <p class="text-muted small mb-0">Üretim bandı ve maliyet</p>
            </a>
        </div>

        <!-- Suppliers -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Supplier" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-info bg-opacity-10 text-info mb-3 mx-auto">
                    <i class="fa-solid fa-truck-field fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Tedarikçiler</h4>
                <p class="text-muted small mb-0">Satıcı firma yönetimi</p>
            </a>
        </div>

        <!-- Transfers -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Transfer" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-danger bg-opacity-10 text-danger mb-3 mx-auto">
                    <i class="fa-solid fa-truck-ramp-box fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Transferler</h4>
                <p class="text-muted small mb-0">Şubeler arası sevkiyat</p>
            </a>
        </div>

        <!-- Units -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="Unit" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-dark bg-opacity-10 text-dark mb-3 mx-auto">
                    <i class="fa-solid fa-scale-balanced fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Birimler</h4>
                <p class="text-muted small mb-0">Ölçü birimi tanımları</p>
            </a>
        </div>

        <!-- Warehouse Movements -->
        <div class="col-xl-3 col-lg-4 col-md-6">
            <a asp-controller="WarehouseMovement" asp-action="Index" class="dashboard-card glass-card text-center p-4 h-100 d-block text-decoration-none">
                <div class="icon-box bg-success bg-opacity-10 text-success mb-3 mx-auto">
                    <i class="fa-solid fa-warehouse fa-2x"></i>
                </div>
                <h4 class="fw-bold mb-1">Depo Hareketleri</h4>
                <p class="text-muted small mb-0">Envanter giriş-çıkış takibi</p>
            </a>
        </div>
    </div>
</div>

<style>
    .nav-dashboard .dashboard-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.2);
    }
    
    .nav-dashboard .dashboard-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
        background: rgba(255, 255, 255, 0.15) !important;
    }

    .icon-box {
        width: 70px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
    }

    h4 {
        color: #f8f9fa;
    }
</style>
